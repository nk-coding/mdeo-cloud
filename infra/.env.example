# PostgreSQL
DATABASE_URL=jdbc:postgresql://postgres:5432/mdeo
DATABASE_USER=mdeo
DATABASE_PASSWORD=changeme_in_production

# Session configuration
SESSION_MAX_IDLE_SECONDS=604800
SESSION_MAX_ABSOLUTE_SECONDS=15552000
CSRF_ROTATION_SECONDS=3600
COOKIE_SECURE=true
COOKIE_SAMESITE=Strict

# CORS
CORS_ALLOWED_HOSTS=your-domain.com

# Admin user (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_in_production

# Plugin cache
PLUGIN_CACHE_TTL_SECONDS=300
