# PostgreSQL Backend Database
DATABASE_URL=jdbc:postgresql://postgres-backend:5432/mdeo
DATABASE_USER=mdeo
DATABASE_PASSWORD=changeme_in_production

# Separate Backend Database Credentials (optional, for production)
# If set, these override DATABASE_USER/PASSWORD for the backend database
BACKEND_DB_USER=mdeo
BACKEND_DB_PASSWORD=changeme_in_production

# Script Execution Service Database
SCRIPT_EXECUTION_DATABASE_URL=jdbc:postgresql://postgres-script:5432/mdeo
SCRIPT_EXECUTION_DATABASE_USER=mdeo
SCRIPT_EXECUTION_DATABASE_PASSWORD=changeme_in_production

# Separate Executions Database Credentials (optional, for production)
# If set, these override DATABASE_USER/PASSWORD for the executions database
SCRIPT_DB_USER=mdeo
SCRIPT_DB_PASSWORD=changeme_in_production
MODEL_TRANSFORMATION_DB_USER=mdeo
MODEL_TRANSFORMATION_DB_PASSWORD=changeme_in_production

# Script Execution Configuration
EXECUTION_TIMEOUT_MS=300000
SCRIPT_EXECUTION_SERVICE_URL=http://script-execution:8081
SCRIPT_EXECUTION_BACKEND_URL=http://backend:8080

# Model Transformation Execution Configuration
MODEL_TRANSFORMATION_EXECUTION_SERVICE_URL=http://model-transformation-execution:8082
TRANSFORMATION_EXECUTION_DATABASE_URL=jdbc:postgresql://postgres-model-transformation:5432/mdeo
TRANSFORMATION_EXECUTION_BACKEND_URL=http://backend:8080

# Session configuration
SESSION_MAX_IDLE_SECONDS=604800
SESSION_MAX_ABSOLUTE_SECONDS=15552000
CSRF_ROTATION_SECONDS=3600
COOKIE_SECURE=true
COOKIE_SAMESITE=Strict

# CORS
CORS_ALLOWED_HOSTS=your-domain.com

# Admin user (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_in_production

# Plugin URL configuration
PLUGIN_BASE_URL=workbench:8080

# Plugin service (metamodel service) host for nginx
PLUGIN_METAMODEL_SERVICE=http://service-metamodel:3000
PLUGIN_MODEL_SERVICE=http://service-model:3000
PLUGIN_SCRIPT_SERVICE=http://service-script:3000
BACKEND_SERVICE=http://backend:8080
