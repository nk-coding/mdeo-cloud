# Default: normalize line endings in the index to LF, check out as-is on all platforms
* text=auto

# Force LF for infrastructure and shell scripts
*.tf        text eol=lf
*.tfvars    text eol=lf
*.hcl       text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.env       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
